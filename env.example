# API Keys & Secrets
# DO NOT ADD REAL VALUES TO THIS FILE. 
# Copy this file to .env and fill in your actual credentials.

# AI/Automation Service Keys
OPENAI_API_KEY=sk-xxxx
ANTHROPIC_API_KEY=sk-ant-xxxx
GOOGLE_API_KEY=xxxx
GITHUB_TOKEN=ghp_xxxx
GH_PAT=ghp_xxxx          # Fine-grained PAT: Contents+Issues+PRs write, Metadata read

# App Configuration
ENVIRONMENT=development  # development, production
LOG_LEVEL=info           # debug, info, warning, error

# Blog Pipeline (local testing only — use GitHub Secrets in CI)
# FEEDLY_BOARD_NAME=Writting Input   # Reference only — Zapier handles the Feedly connection
